# Copie este arquivo para .env e preencha os valores
# NUNCA comite o arquivo .env

# ──────────────────────────────────────────────────────
# Banco de dados (Neon)
# Formato: jdbc:postgresql://<host>/<dbname>?sslmode=require
# Obtenha em: console.neon.tech → seu projeto → Connection string
# ──────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://ep-xxxxx.sa-east-1.aws.neon.tech/carde?sslmode=require
DATABASE_USER=carde_owner
DATABASE_PASSWORD=sua_senha_aqui

# ──────────────────────────────────────────────────────
# CDN (Cloudflare R2)
# Após criar o bucket e habilitar Public Access, copie a URL pública
# Ex: https://pub-abc123.r2.dev  OU  https://media.carde.com.br
# ──────────────────────────────────────────────────────
CDN_BASE_URL=https://pub-xxxxx.r2.dev

# ──────────────────────────────────────────────────────
# Spring
# ──────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
